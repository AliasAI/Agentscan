# 应用配置
APP_NAME=8004scan API
APP_VERSION=1.0.0
DEBUG=true

# 服务器配置
HOST=0.0.0.0
PORT=8000

# 数据库配置
# SQLite (开发环境)
DATABASE_URL=sqlite:///./8004scan.db

# PostgreSQL (生产环境)
# DATABASE_URL=postgresql://user:password@localhost:5432/8004scan

# CORS 配置
CORS_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]

# 区块链 RPC 配置
# 所有 14 个主网统一使用 QuikNode multi-chain RPC（已内置默认值）
# 以下环境变量仅在需要覆盖默认 QuikNode endpoint 时设置
# 留空或不设置 = 使用内置 QuikNode URL

# === Mainnet (Production) - 可选覆盖 ===
# ETHEREUM_RPC_URL=https://dark-divine-pool.quiknode.pro/YOUR_KEY
# POLYGON_RPC_URL=
# BASE_RPC_URL=
# ARBITRUM_RPC_URL=
# OPTIMISM_RPC_URL=
# LINEA_RPC_URL=
# SCROLL_RPC_URL=
# AVALANCHE_RPC_URL=
# CELO_RPC_URL=
# GNOSIS_RPC_URL=
# TAIKO_RPC_URL=
# MEGAETH_RPC_URL=
# BSC_RPC_URL=
# MONAD_RPC_URL=

# === Testnet ===
# SEPOLIA_RPC_URL=

# AI 分类配置（可选）
# 用于自动分类 agent 的 skills 和 domains
# 如果不配置，系统会使用基于关键词的简单分类

# LLM 提供商选择: deepseek, openai, openrouter, anthropic
# deepseek: 推荐，性价比高 (https://platform.deepseek.com/)
# openai: GPT-4o-mini (https://platform.openai.com/)
# openrouter: 支持多种模型 (https://openrouter.ai/)
# anthropic: Claude (https://console.anthropic.com/)
LLM_PROVIDER=deepseek

# 模型名称（可选，如果不指定将使用默认值）
# deepseek: deepseek-chat
# openai: gpt-4o-mini
# openrouter: deepseek/deepseek-chat 或其他支持的模型
# anthropic: claude-3-haiku-20240307
LLM_MODEL_NAME=

# API Keys（根据选择的 LLM_PROVIDER 配置对应的 key）
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
OPENAI_API_KEY=sk-your-openai-key-here
OPENROUTER_API_KEY=sk-your-openrouter-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
