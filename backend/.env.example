# 应用配置
APP_NAME=8004scan API
APP_VERSION=1.0.0
DEBUG=true

# 服务器配置
HOST=0.0.0.0
PORT=8000

# 数据库配置
# SQLite (开发环境)
DATABASE_URL=sqlite:///./8004scan.db

# PostgreSQL (生产环境)
# DATABASE_URL=postgresql://user:password@localhost:5432/8004scan

# CORS 配置
CORS_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]

# 区块链配置
# RPC URLs (获取方式: https://www.alchemy.com/ 或 https://www.quicknode.com/ 或 https://infura.io/)

# === Mainnet (Production) ===
# Ethereum Mainnet - 必填
ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# Polygon Mainnet - 必填（用于同步 Polygon 上的 agents）
# QuikNode: https://dashboard.quicknode.com/ -> Add endpoint -> Polygon Mainnet
# Alchemy: https://dashboard.alchemy.com/ -> Create App -> Polygon Mainnet
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# BNB Smart Chain - 可选（可使用公共 RPC）
BSC_RPC_URL=https://bsc-dataseed.binance.org/

# === Testnet ===
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY
BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# AI 分类配置（可选）
# 用于自动分类 agent 的 skills 和 domains
# 如果不配置，系统会使用基于关键词的简单分类

# LLM 提供商选择: deepseek, openai, openrouter, anthropic
# deepseek: 推荐，性价比高 (https://platform.deepseek.com/)
# openai: GPT-4o-mini (https://platform.openai.com/)
# openrouter: 支持多种模型 (https://openrouter.ai/)
# anthropic: Claude (https://console.anthropic.com/)
LLM_PROVIDER=deepseek

# 模型名称（可选，如果不指定将使用默认值）
# deepseek: deepseek-chat
# openai: gpt-4o-mini
# openrouter: deepseek/deepseek-chat 或其他支持的模型
# anthropic: claude-3-haiku-20240307
LLM_MODEL_NAME=

# API Keys（根据选择的 LLM_PROVIDER 配置对应的 key）
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
OPENAI_API_KEY=sk-your-openai-key-here
OPENROUTER_API_KEY=sk-your-openrouter-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
